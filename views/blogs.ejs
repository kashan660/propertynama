<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blogs</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="nav inner-nav">
    <div class="brand">Property Nama</div>
    <div class="links">
      <a href="/">Home</a>
    </div>
  </nav>
  <main class="content-page">
    <h1>All Blogs</h1>
    <div class="grid">
      <% blogs.forEach(blog => { %>
        <article class="card">
          <h3><%= blog.title %></h3>
          <p><%= blog.excerpt || blog.content.substring(0, 120) %>...</p>
          <a href="/blog/<%= blog.slug %>">Read More</a>
        </article>
      <% }) %>
    </div>
  </main>
</body>
</html>
