<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="nav inner-nav">
    <div class="brand">Property Nama</div>
    <div class="links">
      <a href="/">Home</a>
      <a href="/blogs">Blogs</a>
    </div>
  </nav>
  <main class="content-page">
    <h1><%= page.title %></h1>
    <% if (page.image) { %><img src="<%= page.image %>" alt="<%= page.title %>"><% } %>
    <div class="rich-content"><%- page.content %></div>
    <% if (page.video) { %><iframe src="<%= page.video %>" allowfullscreen></iframe><% } %>
  </main>
</body>
</html>
